# Copy to `.env` for local development:  cp frontend/.env.example frontend/.env

# Backend API base URL (the FastAPI service)
VITE_API_URL=http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000

# Optional
VITE_APP_VERSION=dev
VITE_ENFORCE_SECURE_API=false

# Supabase — not required for the local debug-challenge login (which is built in).
# Leave blank unless you wire up real Supabase auth.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
