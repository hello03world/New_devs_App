# Copy to `.env` for local development:  cp backend/.env.example backend/.env
# These are read by app/config.py (env_file=".env"). Docker Compose sets them for you.

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/propertyflow

# Redis connection (used by the revenue cache)
REDIS_URL=redis://localhost:6379/0

# JWT signing secret (change in any real deployment)
SECRET_KEY=debug_challenge_secret

# Optional Supabase settings — not needed for the built-in challenge login
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
